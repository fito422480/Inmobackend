{
  "name": "inmobackend",
  "version": "1.0.0",
  "description": "NestJS backend con tunnel SSH a Oracle",
  "scripts": {
    "build": "nest build",
    "prestart": "npm run build",
    "start": "node dist/main.js",
    "start:dev": "node dev-runner.js",
    "start:prod": "node dist/main.js",
    "start:tunnel": "concurrently \"npm run start:dev\" \"cloudflared tunnel --url http://localhost:3000\"",
    "export:cuotas-vencidas": "node scripts/export-cuotas-vencidas-csv.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/typeorm": "^11.0.0",
    "oracledb": "^6.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "tunnel-ssh": "^5.1.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
