# ── SSH Tunnel ─────────────────────────────
# Habilita/deshabilita el tunel SSH. En local podes ponerlo en false
SSH_ENABLED=true
SSH_HOST=XXX.XXX.XXX.XXX
SSH_PORT=XX
SSH_USER=usuario_ssh
SSH_PASSWORD=tu_password_aqui
# Opcional: puerto local preferido para el túnel SSH (si está ocupado, busca el siguiente libre)
SSH_LOCAL_PORT=15210

# ── Oracle DB ──────────────────────────────
ORA_HOST=XXX.XXX.XXX.XXX
ORA_PORT=1521
ORA_SERVICE=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ORA_USER=XXXXXXXX
ORA_PASSWORD=tu_password_oracle
# Opcional: ruta al Oracle Instant Client si no está en PATH
ORA_CLIENT_LIB_DIR=
ORA_POOL_MIN=2
ORA_POOL_MAX=10
ORA_POOL_INCREMENT=1

# ── App ────────────────────────────────────
APP_PORT=3000
APP_HOST=0.0.0.0
TRUST_PROXY=false
CORS_ORIGINS=
CORS_CREDENTIALS=false
# API key requerida en el header x-api-key para todos los endpoints
# salvo GET /
API_KEY=cambia-esto-por-un-valor-largo-y-seguro
# Si está en true, loguea SQL generado por TypeORM para requests lentas
LOG_SLOW_SQL=false
# Cache en memoria para respuestas repetidas de /clientes
CLIENTES_CACHE_TTL_MS=15000
CLIENTES_CACHE_MAX_ITEMS=200
# Cache en memoria para respuestas repetidas de /lotes
LOTES_CACHE_TTL_MS=15000
LOTES_CACHE_MAX_ITEMS=200
# Cache en memoria para respuestas repetidas de /cuotas-pagadas
CUOTAS_PAGADAS_CACHE_TTL_MS=15000
CUOTAS_PAGADAS_CACHE_MAX_ITEMS=200
# Cache en memoria para respuestas repetidas de /cuotas-vencidas
CUOTAS_VENCIDAS_CACHE_TTL_MS=15000
CUOTAS_VENCIDAS_CACHE_MAX_ITEMS=200
# Tope máximo de limit para /detalle-cuotas
DETALLE_CUOTAS_MAX_LIMIT=5000
# Cache en memoria para respuestas repetidas de /detalle-cuotas
DETALLE_CUOTAS_CACHE_TTL_MS=15000
DETALLE_CUOTAS_CACHE_MAX_ITEMS=200
# Tope máximo de limit para /estado-cuentas
ESTADO_CUENTAS_MAX_LIMIT=5000
# Cache en memoria para respuestas repetidas de /estado-cuentas
ESTADO_CUENTAS_CACHE_TTL_MS=15000
ESTADO_CUENTAS_CACHE_MAX_ITEMS=200
# Cache en memoria para respuestas repetidas de /total-pagado
TOTAL_PAGADO_CACHE_TTL_MS=15000
TOTAL_PAGADO_CACHE_MAX_ITEMS=200
# Cache en memoria para respuestas repetidas de /total-pagado-mes
TOTAL_PAGADO_MES_CACHE_TTL_MS=15000
TOTAL_PAGADO_MES_CACHE_MAX_ITEMS=200
# Tope maximo de limit para /pagos-por-franja
PAGOS_POR_FRANJA_MAX_LIMIT=5000
# Cache en memoria para respuestas repetidas de /pagos-por-franja
PAGOS_POR_FRANJA_CACHE_TTL_MS=15000
PAGOS_POR_FRANJA_CACHE_MAX_ITEMS=200
